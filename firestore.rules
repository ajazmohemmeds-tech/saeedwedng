rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /guests/{guestId} {
      allow read, write: if true;
    }

    match /visits/{visitId} {
      allow create, update: if true;
      allow read: if true;
    }

    match /config/{document} {
      allow read: if true;
      allow write: if true;
    }
  }
}
